# interview-engine candidate room (apps/web)

# Backend (interview-engine API / Fastify)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws

# Convai voice/avatar layer for the /interview/convai room (browser-native).
# Create a character at https://convai.com, then paste its API key + character ID.
# NOTE: NEXT_PUBLIC_* ships to the browser — use a key scoped/limited to this
# character, or proxy it server-side before going to production.
NEXT_PUBLIC_CONVAI_API_KEY=
# The MetaHuman interviewer character from the UE build (reuse or create a new one):
NEXT_PUBLIC_CONVAI_CHARACTER_ID=fac06dea-682c-11f1-98eb-42010a7be02e

# PRODUCTION PATH (per the team's verified plan): do NOT ship the API key to the
# browser. Instead have FastAPI mint a short-lived token via POST /user/connect
# and set per-candidate persona via POST /character/update {charID, backstory}.
# The NEXT_PUBLIC_* key above is for local dev of this room only.

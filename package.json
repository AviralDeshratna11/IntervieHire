{
  "name": "interviehire",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "concurrently \"npm:dev -w apps/api\" \"npm:dev -w apps/web\"",
    "dev:avatar": "concurrently \"npm:dev -w apps/api\" \"npm:dev -w apps/web\" \"npm --prefix ../Reallusion-web run dev -- --host 127.0.0.1 --port 5173 --strictPort\"",
    "build": "npm run build -w packages/shared && npm run build -w apps/api && npm run build -w apps/web",
    "lint": "npm run lint -w apps/web && npm run lint -w apps/api",
    "db:generate": "npm run db:generate -w apps/api",
    "db:migrate": "npm run db:migrate -w apps/api",
    "seed": "npm run seed -w apps/api"
  },
  "devDependencies": {"concurrently": "^9.1.2"}
}

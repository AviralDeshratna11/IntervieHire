# Normalize all text to LF in the repo; auto-detect binaries.
* text=auto eol=lf

# Explicit binary guards (never touch these).
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.mp4  binary
*.pdf  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.otf  binary
*.zip  binary
*.wasm binary

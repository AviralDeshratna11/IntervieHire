# IntervieHire / InterviewerOS — Environment Variables
# Copy this file to .env and fill in your values.

# REQUIRED
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Databases & queues
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/interviehire?schema=public"
REDIS_URL="redis://localhost:6379"

# LLM / model keys
OPENROUTER_API_KEY="replace-me"
OPENROUTER_MODEL="openai/gpt-4o-mini"
GEMINI_API_KEY="replace-me"
GEMINI_MODEL="gemini-1.5-flash"

# Email (optional)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="user"
SMTP_PASS="pass"
REPORT_FROM="IntervieHire <reports@interviehire.ai>"

# Frontend URLs
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_WS_URL="ws://localhost:4000/ws"
NEXT_PUBLIC_AVATAR_URL="http://localhost:80"

# OPTIONAL
ENV=development                        # development | production
PORT=8000
ALLOWED_ORIGINS=*                      # Comma-separated. Use specific domains in production.
                                       # e.g. https://yourdomain.com,https://app.yourdomain.com
